#include <iostream> 

int Main(){
    int i_1 = 0; 
    int i_2 = 0; 

    for (int i = 0; i < 50; i++ ) {
        int fibc_calc = i_1 + i_2; 

        if (i == 1) {
            i_1 = 1; 
        }
        if (i % 2 == 0) {
            i_2 = fibc_calc;
        } else if ( i % 2 == 1){
            i_1 = fibc_calc;
        }
        std::cout << fibc_calc << std::endl;

    }
    return 0;
}
